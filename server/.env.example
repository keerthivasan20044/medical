# Server Configuration
PORT=5001
NODE_ENV=development

# MongoDB Node
MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/medireach

# Security Matrix
JWT_SECRET=your_super_secret_key_sync_node
JWT_EXPIRE=7d

# Razorpay Payment Gateway (Test Mode)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# Cloudinary Media Mesh (Image/Prescription Sync)
CLOUDINARY_CLOUD_NAME=your_cloud_mesh_name
CLOUDINARY_API_KEY=xxxxxxxxxxxxxxxx
CLOUDINARY_API_SECRET=xxxxxxxxxxxxxxxx

# Fast2SMS OTP Protocol (Indian Numbers)
FAST2SMS_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Firebase Administrative Node (Push Notifications)
FIREBASE_PROJECT_ID=medireach-xxxxx
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nXXXX\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@medireach.iam.gserviceaccount.com

# Google Maps Geospatial API
GOOGLE_MAPS_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Vercel Deployment Sync:
# 1. Add all keys above to Vercel Dashboard -> Settings -> Environment Variables.
# 2. Ensure Client URL is set if different from origin.
