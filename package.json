{
  "name": "medipharm",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace=client\" \"npm run dev --workspace=server\"",
    "build": "npm run build --workspace=client && (robocopy client\\dist dist /E /MOVE || move client\\dist dist || mv client/dist dist || true)",
    "server-start": "npm start --workspace=server",
    "postinstall": "npm install --workspace=client && npm install --workspace=server"
  },
  "workspaces": [
    "client",
    "server"
  ],
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
