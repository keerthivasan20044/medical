{
  "name": "medipharm",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace=client\" \"npm run dev --workspace=server\"",
    "build": "npm run build --workspace=client && node scripts/prep-vercel.js",
    "postinstall": "npm install --include=dev",
    "server-start": "npm start --workspace=server"
  },
  "workspaces": [
    "client",
    "server"
  ],
  "devDependencies": {
    "concurrently": "^8.2.2",
    "fs-extra": "^11.2.0"
  }
}
