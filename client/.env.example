# Razorpay Terminal Node (Public Key)
VITE_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxx

# Firebase Messaging Node (Client SDK)
VITE_FIREBASE_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VITE_FIREBASE_AUTH_DOMAIN=medireach.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=medireach-xxxxx
VITE_FIREBASE_MESSAGING_SENDER_ID=xxxxxxxxxxxx
VITE_FIREBASE_APP_ID=1:xxxxxxxxxxxx:web:xxxxxxxxxxxx

# Google Maps Geospatial API
VITE_GOOGLE_MAPS_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# API Mesh Synchronization
VITE_API_URL=http://localhost:5001/api

# Vercel Deployment Instructions:
# 1. Ensure VITE_API_URL is set to your deployed backend URL.
# 2. Add all VITE_ keys to Vercel UI for the frontend project.
